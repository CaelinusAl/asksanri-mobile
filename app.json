{
  "expo": {
    "name": "AskSanri",
    "slug": "asksanri",
    "scheme": "asksanri",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.caelinusai.asksanri",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sanrı voice input için mikrofon kullanır."
      }
    },
    "android": {
      "package": "com.caelinusai.asksanri",
      "versionCode": 16,
      "usesCleartextTraffic": true,
      "permissions": [
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "f2d81bef-b1a5-4de7-b0cb-22747bfae469"
      },
      "expo": {
        "extra": {
          "EXPO_PUBLIC_API_BASE": "https://sanri-api-2.onrender.com"
        }
      }
    }
  }
}
