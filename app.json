{
  "expo": {
    "name": "AskSanri",
    "slug": "asksanri",
    "scheme": "asksanri",
    "version": "2.1.1",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.caelinusai.asksanri",
      "buildNumber": "3",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AskSanri uses the microphone only when the user starts a voice ritual or chooses voice input. The audio is used to capture the user’s spoken intention, convert speech into text, and generate a ritual or AI response inside the app.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
  "package": "com.caelinusai.asksanri",
  "versionCode": 18,
  "permissions": ["RECORD_AUDIO"],
  "usesCleartextTraffic": true,
  "adaptiveIcon": {
    "foregroundImage": "./assets/adaptive-icon.png",
    "backgroundColor": "#000000"
  }
},
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-notifications",
      "expo-router"
    ],
    "extra": {
      "EXPO_PUBLIC_API_BASE": "https://api.asksanri.com",
      "eas": {
        "projectId": "f2d81bef-b1a5-4de7-b0cb-22747bfae469"
      }
    }
  }
}
